<xml xmlns="https://developers.google.com/blockly/xml" is_dbot="true" collection="false">
  <variables>
    <variable id="max_loss">Max Loss Amount</variable>
    <variable id="target_profit">Expected Profit</variable>
    <variable id="base_stake">Base Stake</variable>
    <variable id="current_stake">Current Stake</variable>
    <variable id="recovery_rate">Recovery Rate</variable>
    <variable id="max_stake">Max Stake</variable>
    <variable id="trigger_digit">Trigger Digit</variable>
    <variable id="barrier">Barrier</variable>
    <variable id="loss_streak">Loss Streak</variable>
    <variable id="max_consecutive_losses">Max Consecutive Losses</variable>
  </variables>
  <block type="trade_definition" id="trade_definition" deletable="false" x="0" y="60">
    <statement name="TRADE_OPTIONS">
      <block type="trade_definition_market" id="market_definition" deletable="false" movable="false">
        <field name="MARKET_LIST">synthetic_index</field>
        <field name="SUBMARKET_LIST">random_index</field>
        <field name="SYMBOL_LIST">R_50</field>
        <next>
          <block type="trade_definition_tradetype" id="trade_type" deletable="false" movable="false">
            <field name="TRADETYPECAT_LIST">digits</field>
            <field name="TRADETYPE_LIST">overunder</field>
            <next>
              <block type="trade_definition_contracttype" id="contract_type" deletable="false" movable="false">
                <field name="TYPE_LIST">both</field>
                <next>
                  <block type="trade_definition_candleinterval" id="candle_interval" deletable="false" movable="false">
                    <field name="CANDLEINTERVAL_LIST">60</field>
                    <next>
                      <block type="trade_definition_restartbuysell" id="restart_buy_sell" deletable="false" movable="false">
                        <field name="TIME_MACHINE_ENABLED">FALSE</field>
                        <next>
                          <block type="trade_definition_restartonerror" id="restart_on_error" deletable="false" movable="false">
                            <field name="RESTARTONERROR">TRUE</field>
                          </block>
                        </next>
                      </block>
                    </next>
                  </block>
                </next>
              </block>
            </next>
          </block>
        </next>
      </block>
    </statement>
    <statement name="INITIALIZATION">
      <block type="variables_set" id="set_max_loss">
        <field name="VAR" id="max_loss">Max Loss Amount</field>
        <value name="VALUE">
          <block type="math_number" id="max_loss_value">
            <field name="NUM">0.75</field>
          </block>
        </value>
        <next>
          <block type="variables_set" id="set_target_profit">
            <field name="VAR" id="target_profit">Expected Profit</field>
            <value name="VALUE">
              <block type="math_number" id="target_profit_value">
                <field name="NUM">9</field>
              </block>
            </value>
            <next>
              <block type="variables_set" id="set_base_stake">
                <field name="VAR" id="base_stake">Base Stake</field>
                <value name="VALUE">
                  <block type="math_number" id="base_stake_value">
                    <field name="NUM">0.35</field>
                  </block>
                </value>
                <next>
                  <block type="variables_set" id="set_current_stake">
                    <field name="VAR" id="current_stake">Current Stake</field>
                    <value name="VALUE">
                      <block type="variables_get" id="base_stake_get_for_current">
                        <field name="VAR" id="base_stake">Base Stake</field>
                      </block>
                    </value>
                    <next>
                      <block type="variables_set" id="set_recovery_rate">
                        <field name="VAR" id="recovery_rate">Recovery Rate</field>
                        <value name="VALUE">
                          <block type="math_number" id="recovery_rate_value">
                            <field name="NUM">0.1</field>
                          </block>
                        </value>
                        <next>
                          <block type="variables_set" id="set_max_stake">
                            <field name="VAR" id="max_stake">Max Stake</field>
                            <value name="VALUE">
                              <block type="math_number" id="max_stake_value">
                                <field name="NUM">0.4</field>
                              </block>
                            </value>
                            <next>
                              <block type="variables_set" id="set_trigger_digit">
                                <field name="VAR" id="trigger_digit">Trigger Digit</field>
                                <value name="VALUE">
                                  <block type="math_number" id="trigger_digit_value">
                                    <field name="NUM">0</field>
                                  </block>
                                </value>
                                <next>
                                  <block type="variables_set" id="set_barrier">
                                    <field name="VAR" id="barrier">Barrier</field>
                                    <value name="VALUE">
                                      <block type="math_number" id="barrier_value">
                                        <field name="NUM">1</field>
                                      </block>
                                    </value>
                                    <next>
                                      <block type="variables_set" id="set_loss_streak">
                                        <field name="VAR" id="loss_streak">Loss Streak</field>
                                        <value name="VALUE">
                                          <block type="math_number" id="loss_streak_value">
                                            <field name="NUM">0</field>
                                          </block>
                                        </value>
                                        <next>
                                          <block type="variables_set" id="set_max_consecutive_losses">
                                            <field name="VAR" id="max_consecutive_losses">Max Consecutive Losses</field>
                                            <value name="VALUE">
                                              <block type="math_number" id="max_consecutive_losses_value">
                                                <field name="NUM">2</field>
                                              </block>
                                            </value>
                                          </block>
                                        </next>
                                      </block>
                                    </next>
                                  </block>
                                </next>
                              </block>
                            </next>
                          </block>
                        </next>
                      </block>
                    </next>
                  </block>
                </next>
              </block>
            </next>
          </block>
        </next>
      </block>
    </statement>
    <statement name="SUBMARKET">
      <block type="trade_definition_tradeoptions" id="trade_options">
        <mutation xmlns="http://www.w3.org/1999/xhtml" has_first_barrier="false" has_second_barrier="false" has_prediction="true"></mutation>
        <field name="DURATIONTYPE_LIST">t</field>
        <value name="DURATION">
          <block type="math_number" id="duration_value">
            <field name="NUM">1</field>
          </block>
        </value>
        <value name="AMOUNT">
          <block type="variables_get" id="current_stake_get_for_trade">
            <field name="VAR" id="current_stake">Current Stake</field>
          </block>
        </value>
        <value name="PREDICTION">
          <shadow type="math_number_positive" id="prediction_shadow" inline="true">
            <field name="NUM">1</field>
          </shadow>
          <block type="variables_get" id="barrier_get_for_trade">
            <field name="VAR" id="barrier">Barrier</field>
          </block>
        </value>
      </block>
    </statement>
  </block>
  <block type="after_purchase" id="after_purchase" x="920" y="60">
    <statement name="AFTERPURCHASE_STACK">
      <block type="controls_if" id="trade_result_handler">
        <mutation xmlns="http://www.w3.org/1999/xhtml" else="1"></mutation>
        <value name="IF0">
          <block type="contract_check_result" id="is_loss">
            <field name="CHECK_RESULT">loss</field>
          </block>
        </value>
        <statement name="DO0">
          <block type="math_change" id="increase_loss_streak">
            <field name="VAR" id="loss_streak">Loss Streak</field>
            <value name="DELTA">
              <shadow type="math_number" id="loss_streak_delta_shadow">
                <field name="NUM">1</field>
              </shadow>
              <block type="math_number" id="loss_streak_delta">
                <field name="NUM">1</field>
              </block>
            </value>
            <next>
              <block type="notify" id="loss_notify">
                <field name="NOTIFICATION_TYPE">error</field>
                <field name="NOTIFICATION_SOUND">announcement</field>
                <value name="MESSAGE">
                  <block type="text" id="loss_message">
                    <field name="TEXT">Loss detected. Stake will step up slightly and stay capped.</field>
                  </block>
                </value>
                <next>
                  <block type="math_change" id="increase_current_stake">
                    <field name="VAR" id="current_stake">Current Stake</field>
                    <value name="DELTA">
                      <shadow type="math_number" id="stake_delta_shadow">
                        <field name="NUM">1</field>
                      </shadow>
                      <block type="math_arithmetic" id="stake_delta_calc">
                        <field name="OP">MULTIPLY</field>
                        <value name="A">
                          <shadow type="math_number" id="stake_delta_a_shadow">
                            <field name="NUM">1</field>
                          </shadow>
                          <block type="variables_get" id="current_stake_get_for_delta">
                            <field name="VAR" id="current_stake">Current Stake</field>
                          </block>
                        </value>
                        <value name="B">
                          <shadow type="math_number" id="stake_delta_b_shadow">
                            <field name="NUM">1</field>
                          </shadow>
                          <block type="variables_get" id="recovery_rate_get">
                            <field name="VAR" id="recovery_rate">Recovery Rate</field>
                          </block>
                        </value>
                      </block>
                    </value>
                    <next>
                      <block type="controls_if" id="max_stake_guard">
                        <value name="IF0">
                          <block type="logic_compare" id="max_stake_compare">
                            <field name="OP">GT</field>
                            <value name="A">
                              <block type="variables_get" id="current_stake_get_for_cap_check">
                                <field name="VAR" id="current_stake">Current Stake</field>
                              </block>
                            </value>
                            <value name="B">
                              <block type="variables_get" id="max_stake_get">
                                <field name="VAR" id="max_stake">Max Stake</field>
                              </block>
                            </value>
                          </block>
                        </value>
                        <statement name="DO0">
                          <block type="variables_set" id="set_capped_stake">
                            <field name="VAR" id="current_stake">Current Stake</field>
                            <value name="VALUE">
                              <block type="variables_get" id="max_stake_get_for_set">
                                <field name="VAR" id="max_stake">Max Stake</field>
                              </block>
                            </value>
                          </block>
                        </statement>
                      </block>
                    </next>
                  </block>
                </next>
              </block>
            </next>
          </block>
        </statement>
        <statement name="ELSE">
          <block type="variables_set" id="reset_loss_streak">
            <field name="VAR" id="loss_streak">Loss Streak</field>
            <value name="VALUE">
              <block type="math_number" id="reset_loss_streak_value">
                <field name="NUM">0</field>
              </block>
            </value>
            <next>
              <block type="variables_set" id="reset_current_stake">
                <field name="VAR" id="current_stake">Current Stake</field>
                <value name="VALUE">
                  <block type="variables_get" id="base_stake_get_for_reset">
                    <field name="VAR" id="base_stake">Base Stake</field>
                  </block>
                </value>
                <next>
                  <block type="notify" id="win_notify">
                    <field name="NOTIFICATION_TYPE">success</field>
                    <field name="NOTIFICATION_SOUND">job-done</field>
                    <value name="MESSAGE">
                      <block type="text" id="win_message">
                        <field name="TEXT">Win detected. Stake reset back to the base amount.</field>
                      </block>
                    </value>
                  </block>
                </next>
              </block>
            </next>
          </block>
        </statement>
        <next>
          <block type="controls_if" id="profit_target_guard">
            <mutation xmlns="http://www.w3.org/1999/xhtml" else="1"></mutation>
            <value name="IF0">
              <block type="logic_compare" id="profit_target_compare">
                <field name="OP">LT</field>
                <value name="A">
                  <block type="total_profit" id="total_profit_check"></block>
                </value>
                <value name="B">
                  <block type="variables_get" id="target_profit_get">
                    <field name="VAR" id="target_profit">Expected Profit</field>
                  </block>
                </value>
              </block>
            </value>
            <statement name="DO0">
              <block type="controls_if" id="max_loss_guard">
                <mutation xmlns="http://www.w3.org/1999/xhtml" else="1"></mutation>
                <value name="IF0">
                  <block type="logic_compare" id="max_loss_compare">
                    <field name="OP">GT</field>
                    <value name="A">
                      <block type="total_profit" id="total_profit_stop_check"></block>
                    </value>
                    <value name="B">
                      <block type="math_arithmetic" id="negative_max_loss">
                        <field name="OP">MULTIPLY</field>
                        <value name="A">
                          <shadow type="math_number" id="negative_max_loss_a_shadow">
                            <field name="NUM">1</field>
                          </shadow>
                          <block type="variables_get" id="max_loss_get">
                            <field name="VAR" id="max_loss">Max Loss Amount</field>
                          </block>
                        </value>
                        <value name="B">
                          <shadow type="math_number" id="negative_max_loss_b_shadow">
                            <field name="NUM">1</field>
                          </shadow>
                          <block type="math_number" id="negative_one">
                            <field name="NUM">-1</field>
                          </block>
                        </value>
                      </block>
                    </value>
                  </block>
                </value>
                <statement name="DO0">
                  <block type="controls_if" id="loss_streak_guard">
                    <mutation xmlns="http://www.w3.org/1999/xhtml" else="1"></mutation>
                    <value name="IF0">
                      <block type="logic_compare" id="loss_streak_compare">
                        <field name="OP">LT</field>
                        <value name="A">
                          <block type="variables_get" id="loss_streak_get">
                            <field name="VAR" id="loss_streak">Loss Streak</field>
                          </block>
                        </value>
                        <value name="B">
                          <block type="variables_get" id="max_consecutive_losses_get">
                            <field name="VAR" id="max_consecutive_losses">Max Consecutive Losses</field>
                          </block>
                        </value>
                      </block>
                    </value>
                    <statement name="DO0">
                      <block type="trade_again" id="trade_again"></block>
                    </statement>
                    <statement name="ELSE">
                      <block type="notify" id="loss_streak_stop_notify">
                        <field name="NOTIFICATION_TYPE">warn</field>
                        <field name="NOTIFICATION_SOUND">announcement</field>
                        <value name="MESSAGE">
                          <block type="text" id="loss_streak_stop_message">
                            <field name="TEXT">Stopped after hitting the consecutive-loss limit.</field>
                          </block>
                        </value>
                      </block>
                    </statement>
                  </block>
                </statement>
                <statement name="ELSE">
                  <block type="notify" id="max_loss_stop_notify">
                    <field name="NOTIFICATION_TYPE">error</field>
                    <field name="NOTIFICATION_SOUND">announcement</field>
                    <value name="MESSAGE">
                      <block type="text" id="max_loss_stop_message">
                        <field name="TEXT">Stopped because the session max loss was reached.</field>
                      </block>
                    </value>
                  </block>
                </statement>
              </block>
            </statement>
            <statement name="ELSE">
              <block type="notify" id="profit_target_notify">
                <field name="NOTIFICATION_TYPE">success</field>
                <field name="NOTIFICATION_SOUND">job-done</field>
                <value name="MESSAGE">
                  <block type="text" id="profit_target_message">
                    <field name="TEXT">Profit target reached. Session stopped cleanly.</field>
                  </block>
                </value>
              </block>
            </statement>
          </block>
        </next>
      </block>
    </statement>
  </block>
  <block type="before_purchase" id="before_purchase" deletable="false" x="0" y="620">
    <statement name="BEFOREPURCHASE_STACK">
      <block type="controls_if" id="entry_rule">
        <value name="IF0">
          <block type="logic_compare" id="trigger_digit_compare">
            <field name="OP">EQ</field>
            <value name="A">
              <block type="last_digit" id="last_digit_for_entry"></block>
            </value>
            <value name="B">
              <block type="variables_get" id="trigger_digit_get">
                <field name="VAR" id="trigger_digit">Trigger Digit</field>
              </block>
            </value>
          </block>
        </value>
        <statement name="DO0">
          <block type="notify" id="entry_notify">
            <field name="NOTIFICATION_TYPE">info</field>
            <field name="NOTIFICATION_SOUND">silent</field>
            <value name="MESSAGE">
              <block type="text" id="entry_message">
                <field name="TEXT">Signal found. Buying DIGIT OVER with the controlled stake.</field>
              </block>
            </value>
            <next>
              <block type="purchase" id="purchase_digit_over">
                <field name="PURCHASE_LIST">DIGITOVER</field>
              </block>
            </next>
          </block>
        </statement>
      </block>
    </statement>
  </block>
</xml>
