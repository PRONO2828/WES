<xml xmlns="https://developers.google.com/blockly/xml" is_dbot="true" collection="false">
  <variables>
    <variable id="var_max_loss">Max Loss Amount</variable>
    <variable id="var_max_consecutive">Max Consecutive Losses</variable>
    <variable id="var_initial_amount">Initial Amount</variable>
    <variable id="var_expected_profit">Expected Profit</variable>
    <variable id="var_ldp">LDP</variable>
    <variable id="var_loss_count">JlhLos</variable>
    <variable id="var_win_amount">Win Amount</variable>
    <variable id="var_text1">text1</variable>
    <variable id="var_text2">text2</variable>
    <variable id="var_text3">text3</variable>
  </variables>
  <block type="trade_definition" id="trade_def" deletable="false" x="0" y="60">
    <statement name="TRADE_OPTIONS">
      <block type="trade_definition_market" id="market" deletable="false" movable="false">
        <field name="MARKET_LIST">synthetic_index</field>
        <field name="SUBMARKET_LIST">random_index</field>
        <field name="SYMBOL_LIST">R_50</field>
        <next>
          <block type="trade_definition_tradetype" id="tradetype" deletable="false" movable="false">
            <field name="TRADETYPECAT_LIST">digits</field>
            <field name="TRADETYPE_LIST">overunder</field>
            <next>
              <block type="trade_definition_contracttype" id="contracttype" deletable="false" movable="false">
                <field name="TYPE_LIST">both</field>
                <next>
                  <block type="trade_definition_candleinterval" id="candleinterval" deletable="false" movable="false">
                    <field name="CANDLEINTERVAL_LIST">60</field>
                    <next>
                      <block type="trade_definition_restartbuysell" id="restartbuysell" deletable="false" movable="false">
                        <field name="TIME_MACHINE_ENABLED">FALSE</field>
                        <next>
                          <block type="trade_definition_restartonerror" id="restartonerror" deletable="false" movable="false">
                            <field name="RESTARTONERROR">FALSE</field>
                          </block>
                        </next>
                      </block>
                    </next>
                  </block>
                </next>
              </block>
            </next>
          </block>
        </next>
      </block>
    </statement>
    <statement name="INITIALIZATION">
      <block type="variables_set" id="set_max_loss">
        <field name="VAR" id="var_max_loss">Max Loss Amount</field>
        <value name="VALUE">
          <block type="math_number" id="max_loss_value">
            <field name="NUM">10</field>
          </block>
        </value>
        <next>
          <block type="variables_set" id="set_max_consecutive">
            <field name="VAR" id="var_max_consecutive">Max Consecutive Losses</field>
            <value name="VALUE">
              <block type="math_number" id="max_consecutive_value">
                <field name="NUM">3</field>
              </block>
            </value>
            <next>
              <block type="variables_set" id="set_expected_profit">
                <field name="VAR" id="var_expected_profit">Expected Profit</field>
                <value name="VALUE">
                  <block type="math_number" id="expected_profit_value">
                    <field name="NUM">10</field>
                  </block>
                </value>
                <next>
                  <block type="variables_set" id="set_win_amount">
                    <field name="VAR" id="var_win_amount">Win Amount</field>
                    <value name="VALUE">
                      <block type="math_number" id="win_amount_value">
                        <field name="NUM">1</field>
                      </block>
                    </value>
                    <next>
                      <block type="variables_set" id="set_initial_amount">
                        <field name="VAR" id="var_initial_amount">Initial Amount</field>
                        <value name="VALUE">
                          <block type="variables_get" id="get_win_amount_init">
                            <field name="VAR" id="var_win_amount">Win Amount</field>
                          </block>
                        </value>
                        <next>
                          <block type="variables_set" id="set_loss_count">
                            <field name="VAR" id="var_loss_count">JlhLos</field>
                            <value name="VALUE">
                              <block type="math_number" id="loss_count_zero">
                                <field name="NUM">0</field>
                              </block>
                            </value>
                            <next>
                              <block type="variables_set" id="set_ldp">
                                <field name="VAR" id="var_ldp">LDP</field>
                                <value name="VALUE">
                                  <block type="math_number" id="ldp_value">
                                    <field name="NUM">1</field>
                                  </block>
                                </value>
                              </block>
                            </next>
                          </block>
                        </next>
                      </block>
                    </next>
                  </block>
                </next>
              </block>
            </next>
          </block>
        </next>
      </block>
    </statement>
    <statement name="SUBMARKET">
      <block type="trade_definition_tradeoptions" id="tradeoptions">
        <mutation xmlns="http://www.w3.org/1999/xhtml" has_first_barrier="false" has_second_barrier="false" has_prediction="true"></mutation>
        <field name="DURATIONTYPE_LIST">t</field>
        <value name="DURATION">
          <block type="math_number" id="duration_value">
            <field name="NUM">2</field>
          </block>
        </value>
        <value name="AMOUNT">
          <block type="variables_get" id="get_initial_amount_trade">
            <field name="VAR" id="var_initial_amount">Initial Amount</field>
          </block>
        </value>
        <value name="PREDICTION">
          <shadow type="math_number_positive" id="prediction_shadow" inline="true">
            <field name="NUM">0</field>
          </shadow>
          <block type="variables_get" id="get_ldp_trade">
            <field name="VAR" id="var_ldp">LDP</field>
          </block>
        </value>
      </block>
    </statement>
  </block>
  <block type="after_purchase" id="after_purchase" x="930" y="60">
    <statement name="AFTERPURCHASE_STACK">
      <block type="controls_if" id="result_if">
        <mutation xmlns="http://www.w3.org/1999/xhtml" else="1"></mutation>
        <value name="IF0">
          <block type="contract_check_result" id="check_loss">
            <field name="CHECK_RESULT">loss</field>
          </block>
        </value>
        <statement name="DO0">
          <block type="math_change" id="increment_loss_count">
            <field name="VAR" id="var_loss_count">JlhLos</field>
            <value name="DELTA">
              <shadow type="math_number" id="loss_delta_shadow">
                <field name="NUM">1</field>
              </shadow>
            </value>
            <next>
              <block type="variables_set" id="reset_stake_on_loss">
                <field name="VAR" id="var_initial_amount">Initial Amount</field>
                <value name="VALUE">
                  <block type="variables_get" id="get_win_amount_loss">
                    <field name="VAR" id="var_win_amount">Win Amount</field>
                  </block>
                </value>
                <next>
                  <block type="text_join" id="join_loss_text">
                    <field name="VARIABLE" id="var_text1">text1</field>
                    <statement name="STACK">
                      <block type="text_statement" id="loss_label">
                        <value name="TEXT">
                          <shadow type="text" id="loss_label_shadow">
                            <field name="TEXT"></field>
                          </shadow>
                          <block type="text" id="loss_text">
                            <field name="TEXT">Lost: </field>
                          </block>
                        </value>
                        <next>
                          <block type="text_statement" id="loss_amount">
                            <value name="TEXT">
                              <shadow type="text" id="loss_amount_shadow">
                                <field name="TEXT"></field>
                              </shadow>
                              <block type="math_single" id="loss_abs">
                                <field name="OP">ABS</field>
                                <value name="NUM">
                                  <shadow type="math_number" id="loss_abs_num_shadow">
                                    <field name="NUM">0</field>
                                  </shadow>
                                  <block type="read_details" id="loss_read_details">
                                    <field name="DETAIL_INDEX">4</field>
                                  </block>
                                </value>
                              </block>
                            </value>
                          </block>
                        </next>
                      </block>
                    </statement>
                    <next>
                      <block type="notify" id="notify_loss">
                        <field name="NOTIFICATION_TYPE">error</field>
                        <field name="NOTIFICATION_SOUND">announcement</field>
                        <value name="MESSAGE">
                          <block type="variables_get" id="get_loss_text">
                            <field name="VAR" id="var_text1">text1</field>
                          </block>
                        </value>
                      </block>
                    </next>
                  </block>
                </next>
              </block>
            </next>
          </block>
        </statement>
        <statement name="ELSE">
          <block type="variables_set" id="reset_loss_count_on_win">
            <field name="VAR" id="var_loss_count">JlhLos</field>
            <value name="VALUE">
              <block type="math_number" id="win_loss_count_zero">
                <field name="NUM">0</field>
              </block>
            </value>
            <next>
              <block type="variables_set" id="reset_stake_on_win">
                <field name="VAR" id="var_initial_amount">Initial Amount</field>
                <value name="VALUE">
                  <block type="variables_get" id="get_win_amount_win">
                    <field name="VAR" id="var_win_amount">Win Amount</field>
                  </block>
                </value>
                <next>
                  <block type="text_join" id="join_win_text">
                    <field name="VARIABLE" id="var_text2">text2</field>
                    <statement name="STACK">
                      <block type="text_statement" id="win_label">
                        <value name="TEXT">
                          <shadow type="text" id="win_label_shadow">
                            <field name="TEXT"></field>
                          </shadow>
                          <block type="text" id="win_text">
                            <field name="TEXT">Won: </field>
                          </block>
                        </value>
                        <next>
                          <block type="text_statement" id="win_amount">
                            <value name="TEXT">
                              <shadow type="text" id="win_amount_shadow">
                                <field name="TEXT"></field>
                              </shadow>
                              <block type="math_single" id="win_abs">
                                <field name="OP">ABS</field>
                                <value name="NUM">
                                  <shadow type="math_number" id="win_abs_num_shadow">
                                    <field name="NUM">0</field>
                                  </shadow>
                                  <block type="read_details" id="win_read_details">
                                    <field name="DETAIL_INDEX">4</field>
                                  </block>
                                </value>
                              </block>
                            </value>
                          </block>
                        </next>
                      </block>
                    </statement>
                    <next>
                      <block type="notify" id="notify_win">
                        <field name="NOTIFICATION_TYPE">success</field>
                        <field name="NOTIFICATION_SOUND">job-done</field>
                        <value name="MESSAGE">
                          <block type="variables_get" id="get_win_text">
                            <field name="VAR" id="var_text2">text2</field>
                          </block>
                        </value>
                      </block>
                    </next>
                  </block>
                </next>
              </block>
            </next>
          </block>
        </statement>
        <next>
          <block type="controls_if" id="profit_target_if">
            <mutation xmlns="http://www.w3.org/1999/xhtml" else="1"></mutation>
            <value name="IF0">
              <block type="logic_compare" id="compare_profit_target">
                <field name="OP">LT</field>
                <value name="A">
                  <block type="total_profit" id="total_profit_target"></block>
                </value>
                <value name="B">
                  <block type="variables_get" id="get_expected_profit">
                    <field name="VAR" id="var_expected_profit">Expected Profit</field>
                  </block>
                </value>
              </block>
            </value>
            <statement name="DO0">
              <block type="controls_if" id="max_loss_if">
                <mutation xmlns="http://www.w3.org/1999/xhtml" else="1"></mutation>
                <value name="IF0">
                  <block type="logic_compare" id="compare_max_loss">
                    <field name="OP">GT</field>
                    <value name="A">
                      <block type="total_profit" id="total_profit_stop"></block>
                    </value>
                    <value name="B">
                      <block type="math_arithmetic" id="negative_max_loss">
                        <field name="OP">MINUS</field>
                        <value name="A">
                          <shadow type="math_number" id="zero_for_max_loss">
                            <field name="NUM">0</field>
                          </shadow>
                        </value>
                        <value name="B">
                          <block type="variables_get" id="get_max_loss">
                            <field name="VAR" id="var_max_loss">Max Loss Amount</field>
                          </block>
                        </value>
                      </block>
                    </value>
                  </block>
                </value>
                <statement name="DO0">
                  <block type="controls_if" id="consecutive_loss_if">
                    <mutation xmlns="http://www.w3.org/1999/xhtml" else="1"></mutation>
                    <value name="IF0">
                      <block type="logic_compare" id="compare_consecutive_losses">
                        <field name="OP">LT</field>
                        <value name="A">
                          <block type="variables_get" id="get_loss_count_for_stop">
                            <field name="VAR" id="var_loss_count">JlhLos</field>
                          </block>
                        </value>
                        <value name="B">
                          <block type="variables_get" id="get_max_consecutive">
                            <field name="VAR" id="var_max_consecutive">Max Consecutive Losses</field>
                          </block>
                        </value>
                      </block>
                    </value>
                    <statement name="DO0">
                      <block type="trade_again" id="trade_again"></block>
                    </statement>
                    <statement name="ELSE">
                      <block type="text_join" id="join_stop_consecutive_text">
                        <field name="VARIABLE" id="var_text3">text3</field>
                        <statement name="STACK">
                          <block type="text_statement" id="stop_consecutive_label">
                            <value name="TEXT">
                              <shadow type="text" id="stop_consecutive_label_shadow">
                                <field name="TEXT"></field>
                              </shadow>
                              <block type="text" id="stop_consecutive_text">
                                <field name="TEXT">Stopped: max consecutive losses reached = </field>
                              </block>
                            </value>
                            <next>
                              <block type="text_statement" id="stop_consecutive_value">
                                <value name="TEXT">
                                  <shadow type="text" id="stop_consecutive_value_shadow">
                                    <field name="TEXT"></field>
                                  </shadow>
                                  <block type="variables_get" id="get_loss_count_text">
                                    <field name="VAR" id="var_loss_count">JlhLos</field>
                                  </block>
                                </value>
                              </block>
                            </next>
                          </block>
                        </statement>
                        <next>
                          <block type="notify" id="notify_stop_consecutive">
                            <field name="NOTIFICATION_TYPE">warn</field>
                            <field name="NOTIFICATION_SOUND">silent</field>
                            <value name="MESSAGE">
                              <block type="variables_get" id="get_stop_consecutive_text">
                                <field name="VAR" id="var_text3">text3</field>
                              </block>
                            </value>
                          </block>
                        </next>
                      </block>
                    </statement>
                  </block>
                </statement>
                <statement name="ELSE">
                  <block type="text_join" id="join_stop_loss_text">
                    <field name="VARIABLE" id="var_text3">text3</field>
                    <statement name="STACK">
                      <block type="text_statement" id="stop_loss_label">
                        <value name="TEXT">
                          <shadow type="text" id="stop_loss_label_shadow">
                            <field name="TEXT"></field>
                          </shadow>
                          <block type="text" id="stop_loss_text">
                            <field name="TEXT">Stopped: max loss reached. Total profit = </field>
                          </block>
                        </value>
                        <next>
                          <block type="text_statement" id="stop_loss_value">
                            <value name="TEXT">
                              <shadow type="text" id="stop_loss_value_shadow">
                                <field name="TEXT"></field>
                              </shadow>
                              <block type="total_profit" id="total_profit_stop_text"></block>
                            </value>
                          </block>
                        </next>
                      </block>
                    </statement>
                    <next>
                      <block type="notify" id="notify_stop_loss">
                        <field name="NOTIFICATION_TYPE">warn</field>
                        <field name="NOTIFICATION_SOUND">silent</field>
                        <value name="MESSAGE">
                          <block type="variables_get" id="get_stop_loss_text">
                            <field name="VAR" id="var_text3">text3</field>
                          </block>
                        </value>
                      </block>
                    </next>
                  </block>
                </statement>
              </block>
            </statement>
            <statement name="ELSE">
              <block type="text_join" id="join_profit_target_text">
                <field name="VARIABLE" id="var_text3">text3</field>
                <statement name="STACK">
                  <block type="text_statement" id="profit_target_label">
                    <value name="TEXT">
                      <shadow type="text" id="profit_target_label_shadow">
                        <field name="TEXT"></field>
                      </shadow>
                      <block type="text" id="profit_target_text">
                        <field name="TEXT">Profit target hit. Total profit = </field>
                      </block>
                    </value>
                    <next>
                      <block type="text_statement" id="profit_target_value">
                        <value name="TEXT">
                          <shadow type="text" id="profit_target_value_shadow">
                            <field name="TEXT"></field>
                          </shadow>
                          <block type="total_profit" id="total_profit_target_text"></block>
                        </value>
                      </block>
                    </next>
                  </block>
                </statement>
                <next>
                  <block type="notify" id="notify_profit_target">
                    <field name="NOTIFICATION_TYPE">success</field>
                    <field name="NOTIFICATION_SOUND">job-done</field>
                    <value name="MESSAGE">
                      <block type="variables_get" id="get_profit_target_text">
                        <field name="VAR" id="var_text3">text3</field>
                      </block>
                    </value>
                  </block>
                </next>
              </block>
            </statement>
          </block>
        </next>
      </block>
    </statement>
  </block>
  <block type="before_purchase" id="before_purchase" deletable="false" x="0" y="980">
    <statement name="BEFOREPURCHASE_STACK">
      <block type="controls_if" id="buy_if_zero">
        <value name="IF0">
          <block type="logic_compare" id="last_digit_zero">
            <field name="OP">EQ</field>
            <value name="A">
              <block type="last_digit" id="current_last_digit"></block>
            </value>
            <value name="B">
              <block type="math_number" id="zero_digit">
                <field name="NUM">0</field>
              </block>
            </value>
          </block>
        </value>
        <statement name="DO0">
          <block type="variables_set" id="set_ldp_before_buy">
            <field name="VAR" id="var_ldp">LDP</field>
            <value name="VALUE">
              <block type="math_number" id="ldp_one_before_buy">
                <field name="NUM">1</field>
              </block>
            </value>
            <next>
              <block type="notify" id="notify_before_buy">
                <field name="NOTIFICATION_TYPE">info</field>
                <field name="NOTIFICATION_SOUND">silent</field>
                <value name="MESSAGE">
                  <shadow type="text" id="buy_message_shadow">
                    <field name="TEXT">abc</field>
                  </shadow>
                  <block type="text" id="buy_message_text">
                    <field name="TEXT">&gt;&gt;&gt; Purchase over 1 &gt;&gt;&gt;</field>
                  </block>
                </value>
                <next>
                  <block type="purchase" id="purchase_over_one">
                    <field name="PURCHASE_LIST">DIGITOVER</field>
                  </block>
                </next>
              </block>
            </next>
          </block>
        </statement>
      </block>
    </statement>
  </block>
</xml>
